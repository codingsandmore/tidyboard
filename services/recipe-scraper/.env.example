# Tidyboard Recipe Scraper — environment variable reference
# Copy to .env and fill in values for local development.
# Never commit .env to source control.

# Log level: DEBUG | INFO | WARNING | ERROR
TIDYBOARD_SCRAPER_LOG_LEVEL=INFO

# TCP port uvicorn listens on
TIDYBOARD_SCRAPER_PORT=8002

# HTTP timeout in seconds for recipe fetch requests
TIDYBOARD_SCRAPER_TIMEOUT_SECONDS=10

# Maximum HTML size accepted (bytes, default 5 MB)
TIDYBOARD_SCRAPER_MAX_HTML_BYTES=5242880
