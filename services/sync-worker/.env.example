# Tidyboard CalDAV Sync Worker — environment variable reference
# Copy to .env and fill in values for local development.
# Never commit .env to source control.

# Log level: DEBUG | INFO | WARNING | ERROR
TIDYBOARD_SYNC_LOG_LEVEL=INFO

# TCP port uvicorn listens on
TIDYBOARD_SYNC_PORT=8001

# HTTP timeout in seconds for CalDAV requests
TIDYBOARD_SYNC_TIMEOUT_SECONDS=30
