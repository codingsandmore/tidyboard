# Tidyboard environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
TIDYBOARD_DB_PASSWORD=change-me-in-production
TIDYBOARD_DATABASE_HOST=localhost
TIDYBOARD_DATABASE_PORT=5432
TIDYBOARD_DATABASE_NAME=tidyboard
TIDYBOARD_DATABASE_USER=tidyboard
TIDYBOARD_DATABASE_PASSWORD=change-me-in-production

# =============================================================================
# REDIS
# =============================================================================
TIDYBOARD_REDIS_HOST=localhost
TIDYBOARD_REDIS_PORT=6379
TIDYBOARD_REDIS_PASSWORD=

# =============================================================================
# JWT / AUTH
# =============================================================================
# Generate with: openssl rand -base64 64
TIDYBOARD_AUTH_JWT_SECRET=
TIDYBOARD_AUTH_OAUTH_GOOGLE_CLIENT_ID=
TIDYBOARD_AUTH_OAUTH_GOOGLE_CLIENT_SECRET=

# =============================================================================
# SERVER
# =============================================================================
TIDYBOARD_SERVER_HOST=0.0.0.0
TIDYBOARD_SERVER_PORT=8080

# =============================================================================
# CORS
# =============================================================================
# Comma-separated list of allowed origins
TIDYBOARD_SERVER_CORS_ORIGINS=http://localhost:3000

# =============================================================================
# LOGGING
# =============================================================================
TIDYBOARD_LOG_LEVEL=info
TIDYBOARD_LOG_FORMAT=json

# =============================================================================
# SERVICES (Python sidecars)
# =============================================================================
SYNC_WORKER_PORT=8081
RECIPE_SCRAPER_PORT=8082

# =============================================================================
# STORAGE
# =============================================================================
# Local mode (default): files written to local disk, served at /media/*
TIDYBOARD_STORAGE_TYPE=local
TIDYBOARD_STORAGE_LOCAL_PATH=./data/media
TIDYBOARD_STORAGE_PUBLIC_BASE_URL=http://localhost:8080/media/

# S3 mode: uncomment and fill in to use AWS S3.
# TIDYBOARD_STORAGE_TYPE=s3
# TIDYBOARD_STORAGE_S3_BUCKET=my-tidyboard-bucket
# TIDYBOARD_STORAGE_S3_REGION=us-east-1
# TIDYBOARD_STORAGE_S3_PREFIX=media/
#
# AWS credentials: PROJECT POLICY — always resolve from ~/.aws named profiles,
# never via static AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY. Set the named
# profile below; in Docker, bind-mount ~/.aws:/home/tidyboard/.aws:ro so the
# container can read it. In Lambda/ECS production, IAM roles take over and
# these values are ignored.
# TIDYBOARD_STORAGE_AWS_PROFILE=default
#
# MinIO local dev (S3-compatible, optional): uncomment and run
# `docker compose --profile s3-dev up` to start a MinIO sidecar. MinIO uses
# static access keys (MINIO_ROOT_USER/MINIO_ROOT_PASSWORD) — still configure
# them via a named profile in ~/.aws/credentials (e.g. `[minio-local]`) and
# set TIDYBOARD_STORAGE_AWS_PROFILE=minio-local. Do NOT set AWS_ACCESS_KEY_ID
# in this file.
# TIDYBOARD_STORAGE_S3_ENDPOINT=http://localhost:9000
# TIDYBOARD_STORAGE_S3_FORCE_PATH_STYLE=true

# S3 integration test (skipped when unset)
# TIDYBOARD_S3_TEST_BUCKET=my-test-bucket

# =============================================================================
# NOTIFICATIONS (optional)
# =============================================================================
TIDYBOARD_NOTIFY_SMTP_USER=
TIDYBOARD_NOTIFY_SMTP_PASSWORD=

# =============================================================================
# WEB FRONTEND
# =============================================================================
# Set this to the public URL of the Go API server
NEXT_PUBLIC_API_URL=http://localhost:8080
