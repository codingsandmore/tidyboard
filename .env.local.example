# .env.local.example — local production environment template.
#
# Copy this file to `.env` (NOT `.env.local`) at the repo root before running:
#   cp .env.local.example .env
#   docker compose -f docker-compose.yml -f docker-compose.local.yml up -d
#
# Compose auto-loads `.env` from the project root for ${VAR} interpolation.
# Override secrets here, NOT in docker-compose.local.yml.

# ── Required: change these before first run ─────────────────────────────────

# Postgres password for the in-stack Postgres container. Anything random and
# at least 16 chars is fine; this database is reachable only from inside the
# docker-compose network in local mode.
TIDYBOARD_DB_PASSWORD=change-me-to-a-long-random-string

# JWT signing secret for local-mode auth (HMAC verifier — local mode does not
# use Cognito). Generate with:
#   openssl rand -base64 32
TIDYBOARD_AUTH_JWT_SECRET=change-me-to-32-bytes-base64

# ── Optional: kiosk URL ────────────────────────────────────────────────────

# CORS origins the API will accept. For a single-machine kiosk this is the
# Next.js dev URL. If you front the stack with Caddy on port 80, add
# http://<mini-pc-ip> here too.
TIDYBOARD_SERVER_CORS_ORIGINS=http://localhost:3000

# What URL the Next.js client uses to reach the API. localhost is correct
# when the kiosk browser runs on the same machine as the docker stack.
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Optional: AI / Ollama ──────────────────────────────────────────────────

# When using --profile ollama (embedded), leave these unset; the API will
# discover ollama at http://ollama:11434.
# When pointing at a remote LAN Ollama, set:
#   TIDYBOARD_AI_OLLAMA_URL=http://192.168.1.50:11434
