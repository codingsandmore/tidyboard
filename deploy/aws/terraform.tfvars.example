# ── Copy this file to terraform.tfvars and fill in your values ────────────────
# terraform.tfvars is git-ignored — never commit real values.
#
# Path C single-EC2 deployment (~$17/mo): one t4g.small running docker compose
# + Caddy, reusing a shared RDS Postgres via schema isolation. No ALB, no ECS,
# no CloudFront, no Aurora.

# AWS named profile from ~/.aws/credentials
aws_profile = "tidyboard"

# AWS region. cutly-db lives in us-east-1, so keep the Tidyboard stack there too.
aws_region = "us-east-1"

# Short name used as a resource prefix.
project = "tidyboard"

# Environment label (prod, staging, dev). Also determines the SSM path prefix
# /tidyboard/<environment>/... where the runtime secrets are read from.
environment = "prod"

# Public apex domain. Caddy on the EC2 obtains Let's Encrypt certs for this and www.
domain_name = "tidyboard.example.com"

# Set to true if your domain is managed by Route 53 in the same AWS account;
# apex + www A records will be created pointing at the EC2 EIP.
create_route53_records = false

# Required when create_route53_records = true. Find it in Route 53 → Hosted zones.
# route53_zone_id = "Z1234567890ABC"

# ── Database (shared cutly-db Postgres) ───────────────────────────────────────
# These defaults reference the user's existing cutly-db instance; override for
# a different shared DB. Tidyboard gets its own `tidyboard` role + schema —
# see deploy/aws/scripts/bootstrap-db.sql.
# db_host              = "cutly-db.c858qwm0sac7.us-east-1.rds.amazonaws.com"
# db_port              = 5432
# db_name              = "cutlist"    # the RDS DBName, not the instance identifier
# db_username          = "tidyboard"
# db_schema            = "tidyboard"
# db_security_group_id = "sg-001c4c1a130b6ab42"
# existing_vpc_id      = "vpc-0c41d6012793ea910"

# ── EC2 ───────────────────────────────────────────────────────────────────────
# SSH key pair — create in AWS console first, download the .pem, then paste the
# key name here.
ssh_key_name = "tidyboard"

# Optional overrides (uncomment to change):
# ec2_instance_type  = "t4g.small"
# ec2_volume_size_gb = 30
# admin_ssh_cidr     = "203.0.113.0/24"   # narrow to your IP in production
# repo_url           = "git@github.com:codingsandmore/tidyboard.git"
# repo_branch        = "main"
